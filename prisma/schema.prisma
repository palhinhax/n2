// Nacional 2 — schema
// NOTA: provider "sqlite" para arrancar sem instalar nada.
// Para produção: muda para "postgresql" e ajusta o DATABASE_URL no .env.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         String   @default("USER") // USER | ADMIN
  phone        String?
  district     String?
  createdAt    DateTime @default(now())

  // ---- Perfil / conta ----
  accountType String  @default("PARTICULAR") // PARTICULAR | STAND
  avatarUrl   String? // foto de perfil ou logótipo do stand
  bio         String? // "sobre mim" / "sobre o stand"
  address     String?
  postalCode  String?
  city        String?
  // dados de stand
  standName   String? // nome comercial
  nif         String?
  website     String?
  hours       String? // horário de funcionamento (texto livre)

  posts         Post[]
  cars          Car[]
  offers        Offer[]
  favorites     Favorite[]
  savedSearches SavedSearch[]
  notifications Notification[]
}

// Pesquisa guardada por um utilizador, para alertas de novos carros / preço.
model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  query     String // JSON dos filtros (marca, modelo, precoMax, fuel, …)
  lastCount Int      @default(0) // nº de resultados na última visita
  notifiedCount Int  @default(0) // nº de resultados na última notificação (cron de alertas)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Favorito/guardar (serve também de "like"). Guarda o preço no momento
// para detetar descidas/subidas e notificar o utilizador.
model Favorite {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // um favorito aponta para um carro do site OU um anúncio externo
  carId     String?
  car       Car?            @relation(fields: [carId], references: [id], onDelete: Cascade)
  listingId String?
  listing   ScrapedListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  priceWhenSaved Int? // preço no momento em que foi guardado
  seenPrice      Int? // último preço já "visto" pelo utilizador (para notificações)
  notifiedPrice  Int? // último preço já notificado pelo cron de alertas (evita repetir)
  createdAt      DateTime @default(now())

  @@unique([userId, carId])
  @@unique([userId, listingId])
  @@index([carId])
  @@index([listingId])
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  models Model[]
  cars   Car[]
}

model Model {
  id      Int    @id @default(autoincrement())
  name    String
  brandId Int
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  cars    Car[]

  @@unique([brandId, name])
}

model Car {
  id          String  @id @default(cuid())
  ownerId     String
  owner       User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  brandId     Int
  brand       Brand   @relation(fields: [brandId], references: [id])
  modelId     Int
  model       Model   @relation(fields: [modelId], references: [id])
  version     String?
  year        Int
  km          Int
  fuel        String // Gasolina | Diesel | Híbrido | Híbrido Plug-In | Elétrico | GPL
  gearbox     String // Manual | Automática
  power       Int?
  evRange     Int? // autonomia WLTP (km) — elétricos e híbridos plug-in
  plate       String?
  color       String  @default("#CE994B")
  description String?
  district    String?

  // venda (um carro pode estar na garagem sem estar à venda)
  forSale    Boolean @default(false)
  price      Int?
  negotiable Boolean @default(true)
  status     String  @default("GARAGE") // GARAGE | PENDING | APPROVED | REJECTED

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  photos    Photo[]
  offers    Offer[]
  reminders Reminder[]
  views     CarView[]
  favorites Favorite[]
  pricePoints PricePoint[]
}

// Evento de navegação para o motor de recomendações da homepage.
// Características denormalizadas (marca/preço/ano/…) para o perfil de gosto
// funcionar igual para carros do site e anúncios externos, e para os eventos
// sobreviverem quando um anúncio é apagado. Sem FKs de propósito.
model BrowseEvent {
  id        String   @id @default(cuid())
  visitorId String // cookie n2vid — existe mesmo sem login
  userId    String? // preenchido quando autenticado (junta histórico anónimo + conta)
  kind      String // VIEW | SEARCH | FAVORITE
  carId     String?
  listingId String?
  brand     String?
  model     String?
  fuel      String?
  gearbox   String?
  price     Int? // em SEARCH é o precoMax do filtro
  year      Int? // em SEARCH é o anoMin do filtro
  query     String? // assinatura da pesquisa (dedupe de SEARCH)
  createdAt DateTime @default(now())

  @@index([visitorId, createdAt])
  @@index([userId, createdAt])
}

model CarView {
  id          String   @id @default(cuid())
  carId       String
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  visitorHash String // identifica um visitante (via cookie) para contar pessoas únicas
  createdAt   DateTime @default(now())

  @@index([carId])
  @@index([carId, visitorHash])
}

model Photo {
  id       String @id @default(cuid())
  carId    String
  car      Car    @relation(fields: [carId], references: [id], onDelete: Cascade)
  key      String
  url      String
  position Int    @default(0)
}

model Offer {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  amount    Int
  message   String?
  status    String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | WITHDRAWN
  createdAt DateTime @default(now())
}

// ---------- Scraping (OLX / Standvirtual / Piscapisca) ----------

model ScrapedListing {
  id          String   @id @default(cuid())
  source      String // OLX | STANDVIRTUAL | PISCAPISCA
  externalId  String // id do anúncio no site de origem
  url         String // link para o anúncio original
  title       String // título limpo "Marca Modelo Versão" (normalizado)
  rawTitle    String? // título original do site de origem (antes da limpeza)
  brand       String?
  model       String?
  version     String? // motorização/acabamento — ex. "1.5 dCi Nacional"
  year        Int?
  km          Int?
  fuel        String?
  gearbox     String?
  power       Int? // cv
  displacement Int? // cm3
  price       Int? // EUR
  location    String?
  sellerType  String? // Particular | Profissional
  sellerName  String?
  imageUrls   String   @default("[]") // JSON array de URLs (hotlink CDN de origem)
  active      Boolean  @default(true) // false = deixou de aparecer no site
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  // ---- Detalhe enriquecido (preenchido sob demanda ao abrir o anúncio) ----
  description      String? // texto do anúncio
  equipment        String  @default("[]") // JSON: [{ group, items: string[] }]
  color            String?
  doors            Int?
  seats            Int?
  drivetrain       String? // Tracção dianteira/traseira/integral
  bodyType         String? // segmento/carroçaria
  condition        String? // Usado | Novo
  registrationDate String? // ex. "Abril 2024"
  warranty         String? // ex. "18 Meses"
  co2              Int?
  detailsFetchedAt DateTime? // null = ainda não enriquecido

  // deduplicação entre fontes (mesmo carro em vários sites)
  dedupeKey   String? // brand|model|year|km normalizado
  isDuplicate Boolean @default(false) // true = cópia escondida da listagem

  // qualidade de dados (ver lib/listing-quality.ts) — anúncios com km/ano/preço
  // implausíveis saem das listagens, estatísticas e sitemaps; a página de
  // detalhe fica noindex com aviso "por confirmar".
  suspicious        Boolean @default(false)
  suspiciousReasons String  @default("[]") // JSON: ["km_implausivel", ...]

  // histórico de preço (descida) — preenchido quando o scraper deteta mudança
  previousPrice  Int?
  priceChangedAt DateTime?

  favorites   Favorite[]
  pricePoints PricePoint[]

  @@unique([source, externalId])
  @@index([source, active])
  @@index([brand, model])
  @@index([price])
  @@index([dedupeKey])
  @@index([active, isDuplicate])
  @@index([active, isDuplicate, suspicious])
}

// Ponto do histórico de preço de um anúncio (do site OU externo).
// Regista-se um ponto na criação e um por cada mudança de preço detetada —
// permite mostrar a linha temporal completa e contar mudanças.
model PricePoint {
  id        String   @id @default(cuid())
  carId     String?
  car       Car?            @relation(fields: [carId], references: [id], onDelete: Cascade)
  listingId String?
  listing   ScrapedListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  price     Int
  createdAt DateTime @default(now())

  @@index([carId, createdAt])
  @@index([listingId, createdAt])
}

// Notificação in-app (alertas inteligentes): descidas de preço nos favoritos,
// carros novos nas pesquisas guardadas, etc.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String // PRICE_DROP | NEW_MATCHES
  title     String
  body      String?
  url       String? // link interno (ex. /carros/externo/xyz)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// Relatório de modelo gerado por IA e cacheado (problemas conhecidos,
// verificações antes de comprar) — partilhado por todos os anúncios do
// mesmo marca+modelo+combustível, para não repetir chamadas ao modelo.
model ModelReport {
  id        String   @id @default(cuid())
  key       String   @unique // "marca|modelo|combustível" normalizado
  brand     String
  model     String
  fuel      String?
  content   String // JSON: { issues: [...], checks: [...], summary }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contador de uso diário das funcionalidades de IA (chat, avaliação) por
// utilizador — permite impor limites diários e controlar custos.
model AiUsage {
  id     String @id @default(cuid())
  userId String
  day    String // "YYYY-MM-DD" (Europe/Lisbon)
  kind   String // "chat" | "avaliar"
  count  Int    @default(0)

  @@unique([userId, day, kind])
}

// Estado/cursor do scraper (para retomar entre execuções — ex. cron da Vercel)
model ScrapeState {
  id        String   @id
  data      String   @default("{}")
  updatedAt DateTime @updatedAt
}

model Reminder {
  id      String   @id @default(cuid())
  carId   String
  car     Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  type    String // IPO | Manutenção | Seguro | IUC | Pneus | Outro
  title   String
  dueDate DateTime
  notes   String?
  done    Boolean  @default(false)
}

// Pedido de proposta de financiamento (lead) submetido a partir de um anúncio.
model FinanceLead {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  carId           String? // anúncio do site
  listingId       String? // anúncio externo
  vehicleTitle    String?
  price           Int
  downPayment     Int
  months          Int
  monthlyEstimate Int
  status          String   @default("NEW") // NEW | CONTACTED | CLOSED
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

// ---------- Importação de carros da Europa ----------

// Fonte de scraping estrangeira (gerida no painel de admin). O campo `adapter`
// aponta para um adaptador em scripts/scraper/foreign/sites — a mesma
// implementação serve vários países/instâncias com configuração diferente.
model ImportSource {
  id        String    @id @default(cuid())
  slug      String    @unique // ex.: "autoscout24-de"
  name      String // ex.: "AutoScout24 Alemanha"
  adapter   String // "autoscout24" | "demo" | ...
  country   String // ISO-2: DE FR BE NL ES IT LU AT
  baseUrl   String
  enabled   Boolean   @default(true)
  notes     String?
  lastRunAt DateTime?
  lastError String? // último erro (limpo quando uma página corre bem)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Anúncio estrangeiro (Europa) — alimenta a área "Importar carros da Europa".
// Sem FK para ImportSource de propósito (igual ao ScrapedListing): apagar ou
// renomear uma fonte não pode apagar o histórico de anúncios.
model ForeignListing {
  id         String @id @default(cuid())
  sourceSlug String // slug da ImportSource (ex.: "autoscout24-de")
  externalId String // id do anúncio no site de origem
  url        String // link para o anúncio original
  country    String // ISO-2 do país do anúncio
  region     String? // cidade/região no país de origem

  title    String // título limpo "Marca Modelo Versão"
  rawTitle String?
  brand    String?
  model    String?
  version  String?

  year              Int?
  firstRegistration String? // 1ª matrícula, ex. "2019-03"
  km                Int?
  price             Int? // preço na moeda de origem (inteiro)
  currency          String  @default("EUR")
  priceEur          Int? // preço convertido para EUR (igual a price se EUR)
  fuel              String? // normalizado PT: Gasolina | Diesel | Híbrido | ...
  gearbox           String? // Manual | Automática
  displacement      Int? // cm3
  power             Int? // cv
  co2               Int? // g/km
  emissionStandard  String? // ex. "Euro 6d"
  bodyType          String?
  doors             Int?
  seats             Int?

  sellerType  String? // Particular | Profissional
  sellerName  String?
  sellerPhone String? // só quando público no site de origem
  sellerEmail String? // só quando público no site de origem
  imageUrls   String  @default("[]") // JSON array (hotlink CDN de origem)
  description String?

  // moderação/ciclo de vida: anúncios entram APPROVED; o admin pode rejeitar
  // ou marcar como expirado manualmente. `active` é gerido pelo scraper.
  status        String   @default("APPROVED") // PENDING | APPROVED | REJECTED | EXPIRED
  active        Boolean  @default(true)
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  lastCheckedAt DateTime @default(now())

  // deduplicação entre fontes/países + qualidade de dados
  dedupeKey         String?
  isDuplicate       Boolean @default(false)
  suspicious        Boolean @default(false)
  suspiciousReasons String  @default("[]")

  // ---- custo de importação pré-calculado (cache, ver lib/import-cost.ts) ----
  // Recalculado em cada upsert e no fim de cada ciclo de scraping, para os
  // filtros "custo total" / "poupança" funcionarem como colunas indexadas.
  importCostJson String? // JSON ImportCostBreakdown
  importTotalEur Int? // custo total estimado legalizado em PT
  ptMarketMedian Int? // mediana de preço em PT (comparável)
  savingsEur     Int? // ptMarketMedian - importTotalEur (pode ser negativo)
  dealRating     String? // EXCELLENT | GOOD | NEUTRAL | BAD

  leads ImportLead[]

  @@unique([sourceSlug, externalId])
  @@index([country, active])
  @@index([brand, model])
  @@index([active, status, isDuplicate, suspicious])
  @@index([importTotalEur])
  @@index([savingsEur])
  @@index([dedupeKey])
  @@index([lastSeenAt])
}

// Pedido de ajuda para importar um carro (lead) — botão "Quero importar".
model ImportLead {
  id           String          @id @default(cuid())
  name         String
  email        String
  phone        String?
  listingId    String?
  listing      ForeignListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  vehicleTitle String?
  country      String? // país do carro
  budget       Int? // orçamento total do cliente (EUR)
  contactPref  String? // email | telefone | whatsapp
  message      String?
  status       String          @default("NEW") // NEW | CONTACTED | CLOSED
  createdAt    DateTime        @default(now())

  @@index([status, createdAt])
}

// Log do scraping de fontes estrangeiras (visível no painel de admin).
model ImportScrapeLog {
  id         String   @id @default(cuid())
  sourceSlug String
  level      String // INFO | ERROR
  message    String
  createdAt  DateTime @default(now())

  @@index([sourceSlug, createdAt])
  @@index([createdAt])
}

// Pressupostos configuráveis do cálculo de custos de importação (editável no
// admin) — evita hardcodar taxas/valores que mudam com o Orçamento do Estado.
model ImportConfig {
  id        String   @id // "assumptions"
  data      String   @default("{}")
  updatedAt DateTime @updatedAt
}

// Denúncia de um anúncio (vai para o painel de admin, não para email).
model Report {
  id           String   @id @default(cuid())
  kind         String // car | listing
  carId        String?
  listingId    String?
  vehicleTitle String?
  reason       String // motivo (ver REPORT_REASONS)
  note         String?
  reporterId   String? // userId se autenticado
  status       String   @default("NEW") // NEW | REVIEWED | DISMISSED
  createdAt    DateTime @default(now())

  @@index([status, createdAt])
}
