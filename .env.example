# Base de dados
# Dev rápido (SQLite) — não precisa de instalar nada:
DATABASE_URL="file:./dev.db"
# Produção (PostgreSQL) — muda também o provider em prisma/schema.prisma:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/nacional2"

# Auth.js
AUTH_SECRET="gera-com: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Backblaze B2 (S3 compatível) — opcional; sem isto as fotos usam a ilustração
B2_ENDPOINT=""            # ex: https://s3.eu-central-003.backblazeb2.com
B2_REGION="eu-central-003"
B2_KEY_ID=""
B2_APP_KEY=""
B2_BUCKET=""
B2_PUBLIC_URL=""          # ex: https://f003.backblazeb2.com/file/o-teu-bucket

# Application
NODE_ENV="development"

# Importação de carros da Europa (scraping de fontes estrangeiras) — opcional
# IMPORT_SCRAPE_INTERVAL_DAYS="3"   # dias entre ciclos completos
# IMPORT_SCRAPE_BATCH_PAGES="60"    # páginas por invocação do cron
# IMPORT_SCRAPE_MAX_PAGES="20"      # páginas máx. por fonte e ciclo
